# VibeBench Environment Variables Template
# Copy this file to .env and fill in your actual API keys.

# --- Model Provider Keys ---
# Get your Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get your Groq key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# --- Execution Settings (Optional) ---
# Default CPU limit in seconds
VIBEBENCH_CPU_LIMIT=5
# Default Memory limit in MB
VIBEBENCH_MEMORY_LIMIT=512
